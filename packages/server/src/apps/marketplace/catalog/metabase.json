{
  "id": "metabase",
  "name": "Metabase",
  "description": "Business intelligence and analytics dashboards — ask questions, get charts",
  "icon": "PieChart",
  "category": "analytics",
  "color": "#509ee3",
  "website": "https://www.metabase.com",
  "license": "AGPL-3.0",
  "services": {
    "app": {
      "image": "metabase/metabase:latest",
      "port": 3000,
      "healthCheck": "/api/health",
      "env": {
        "MB_DB_FILE": "/metabase-data/metabase.db",
        "JAVA_TIMEZONE": "UTC"
      },
      "volumes": ["data:/metabase-data"]
    }
  },
  "userEnv": [],
  "resources": { "minRam": "1536MB", "estimatedDisk": "1GB" }
}
