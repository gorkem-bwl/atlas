{
  "id": "chatwoot",
  "name": "Chatwoot",
  "description": "Open-source helpdesk and live chat — manage customer conversations across channels",
  "icon": "MessageSquare",
  "category": "support",
  "color": "#1f93ff",
  "website": "https://www.chatwoot.com",
  "license": "MIT",
  "services": {
    "app": {
      "image": "chatwoot/chatwoot:v4.12.1",
      "port": 3000,
      "healthCheck": "/health",
      "entrypoint": "docker/entrypoints/rails.sh",
      "command": ["bundle", "exec", "rails", "s", "-p", "3000", "-b", "0.0.0.0"],
      "env": {
        "RAILS_ENV": "production",
        "NODE_ENV": "production",
        "INSTALLATION_ENV": "docker",
        "SECRET_KEY_BASE": "$SECRET_RAILS_KEY_64",
        "FRONTEND_URL": "$APP_URL",
        "POSTGRES_HOST": "db",
        "POSTGRES_PORT": "5432",
        "POSTGRES_USERNAME": "chatwoot",
        "POSTGRES_PASSWORD": "$SECRET_DB_PASS_32",
        "REDIS_URL": "redis://redis:6379",
        "REDIS_PASSWORD": "$SECRET_REDIS_PASS_32",
        "RAILS_LOG_TO_STDOUT": "true",
        "LOG_LEVEL": "info",
        "ENABLE_ACCOUNT_SIGNUP": "false",
        "ACTIVE_STORAGE_SERVICE": "local",
        "FORCE_SSL": "false"
      },
      "volumes": ["storage:/app/storage"],
      "dependsOn": ["db", "redis"]
    },
    "sidekiq": {
      "image": "chatwoot/chatwoot:v4.12.1",
      "entrypoint": "docker/entrypoints/rails.sh",
      "command": ["bundle", "exec", "sidekiq", "-C", "config/sidekiq.yml"],
      "env": {
        "RAILS_ENV": "production",
        "NODE_ENV": "production",
        "INSTALLATION_ENV": "docker",
        "SECRET_KEY_BASE": "$SECRET_RAILS_KEY_64",
        "FRONTEND_URL": "$APP_URL",
        "POSTGRES_HOST": "db",
        "POSTGRES_PORT": "5432",
        "POSTGRES_USERNAME": "chatwoot",
        "POSTGRES_PASSWORD": "$SECRET_DB_PASS_32",
        "REDIS_URL": "redis://redis:6379",
        "REDIS_PASSWORD": "$SECRET_REDIS_PASS_32",
        "RAILS_LOG_TO_STDOUT": "true",
        "LOG_LEVEL": "info",
        "ACTIVE_STORAGE_SERVICE": "local"
      },
      "volumes": ["storage:/app/storage"],
      "dependsOn": ["db", "redis"]
    },
    "db": {
      "image": "pgvector/pgvector:pg16",
      "env": {
        "POSTGRES_DB": "chatwoot_production",
        "POSTGRES_USER": "chatwoot",
        "POSTGRES_PASSWORD": "$SECRET_DB_PASS_32"
      },
      "volumes": ["pgdata:/var/lib/postgresql/data"],
      "healthCheck": "pg_isready -U chatwoot"
    },
    "redis": {
      "image": "redis:7-alpine",
      "env": {
        "REDIS_PASSWORD": "$SECRET_REDIS_PASS_32"
      },
      "volumes": ["redisdata:/data"],
      "healthCheck": "redis-cli ping"
    }
  },
  "userEnv": [
    {
      "key": "MAILER_SENDER_EMAIL",
      "label": "Sender email for outgoing emails",
      "required": false,
      "default": "Chatwoot <noreply@localhost>"
    },
    {
      "key": "SMTP_ADDRESS",
      "label": "SMTP server address",
      "required": false
    },
    {
      "key": "SMTP_PORT",
      "label": "SMTP server port",
      "required": false,
      "default": "587"
    },
    {
      "key": "SMTP_USERNAME",
      "label": "SMTP username",
      "required": false
    },
    {
      "key": "SMTP_PASSWORD",
      "label": "SMTP password",
      "required": false
    }
  ],
  "resources": { "minRam": "2048MB", "estimatedDisk": "2GB" }
}
