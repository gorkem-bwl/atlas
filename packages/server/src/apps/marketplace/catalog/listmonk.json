{
  "id": "listmonk",
  "name": "Listmonk",
  "description": "High-performance newsletter and mailing list manager — self-hosted email marketing",
  "icon": "Mail",
  "category": "email-marketing",
  "color": "#7c3aed",
  "website": "https://listmonk.app",
  "license": "AGPL-3.0",
  "defaultCredentials": { "username": "admin", "password": "admin" },
  "services": {
    "app": {
      "image": "listmonk/listmonk:latest",
      "port": 9000,
      "healthCheck": "/health",
      "command": ["sh", "-c", "./listmonk --install --idempotent --yes --config '' && ./listmonk --upgrade --yes --config '' && ./listmonk --config ''"],
      "env": {
        "LISTMONK_app__address": "0.0.0.0:9000",
        "LISTMONK_db__host": "db",
        "LISTMONK_db__port": "5432",
        "LISTMONK_db__user": "listmonk",
        "LISTMONK_db__password": "$SECRET_DB_PASS_32",
        "LISTMONK_db__database": "listmonk",
        "LISTMONK_db__ssl_mode": "disable",
        "LISTMONK_db__max_open": "25",
        "LISTMONK_db__max_idle": "25",
        "LISTMONK_db__max_lifetime": "300s",
        "LISTMONK_ADMIN_USER": "admin",
        "LISTMONK_ADMIN_PASSWORD": "admin",
        "TZ": "Etc/UTC"
      },
      "volumes": ["uploads:/listmonk/uploads"],
      "dependsOn": ["db"]
    },
    "db": {
      "image": "postgres:17-alpine",
      "env": {
        "POSTGRES_DB": "listmonk",
        "POSTGRES_USER": "listmonk",
        "POSTGRES_PASSWORD": "$SECRET_DB_PASS_32"
      },
      "volumes": ["data:/var/lib/postgresql/data"],
      "healthCheck": "pg_isready -U listmonk"
    }
  },
  "userEnv": [],
  "resources": { "minRam": "256MB", "estimatedDisk": "500MB" }
}
