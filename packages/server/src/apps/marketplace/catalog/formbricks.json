{
  "id": "formbricks",
  "name": "Formbricks",
  "description": "Open-source survey & experience management — in-app surveys, link surveys, and user research",
  "icon": "ClipboardList",
  "category": "forms",
  "color": "#00C4B8",
  "website": "https://formbricks.com",
  "license": "AGPL-3.0",
  "services": {
    "app": {
      "image": "ghcr.io/formbricks/formbricks:latest",
      "port": 3000,
      "healthCheck": "/health",
      "env": {
        "WEBAPP_URL": "$APP_URL",
        "NEXTAUTH_URL": "$APP_URL",
        "DATABASE_URL": "postgresql://formbricks:$SECRET_DB_PASS_32@db:5432/formbricks?schema=public",
        "NEXTAUTH_SECRET": "$SECRET_NEXTAUTH_64",
        "ENCRYPTION_KEY": "$SECRET_ENCRYPTION_64",
        "CRON_SECRET": "$SECRET_CRON_64",
        "REDIS_URL": "redis://redis:6379",
        "EMAIL_VERIFICATION_DISABLED": "1",
        "PASSWORD_RESET_DISABLED": "1"
      },
      "dependsOn": ["db", "redis"]
    },
    "db": {
      "image": "pgvector/pgvector:pg17",
      "env": {
        "POSTGRES_DB": "formbricks",
        "POSTGRES_USER": "formbricks",
        "POSTGRES_PASSWORD": "$SECRET_DB_PASS_32"
      },
      "volumes": ["pgdata:/var/lib/postgresql/data"],
      "healthCheck": "pg_isready -U formbricks"
    },
    "redis": {
      "image": "valkey/valkey:8-alpine",
      "volumes": ["redisdata:/data"],
      "healthCheck": "valkey-cli ping"
    }
  },
  "userEnv": [],
  "resources": { "minRam": "1024MB", "estimatedDisk": "1GB" }
}
