{
  "id": "vaultwarden",
  "name": "Vaultwarden",
  "description": "Bitwarden-compatible password manager — self-hosted vault for passwords, keys and secrets",
  "icon": "KeyRound",
  "category": "security",
  "color": "#175DDC",
  "website": "https://github.com/dani-garcia/vaultwarden",
  "license": "AGPL-3.0",
  "services": {
    "app": {
      "image": "vaultwarden/server:latest",
      "port": 80,
      "healthCheck": "/alive",
      "env": {
        "DOMAIN": "$APP_URL",
        "SIGNUPS_ALLOWED": "true",
        "ADMIN_TOKEN": "$SECRET_ADMIN_TOKEN_48",
        "DATABASE_URL": "data/db.sqlite3",
        "PUSH_ENABLED": "false",
        "LOG_LEVEL": "info",
        "ROCKET_ADDRESS": "0.0.0.0",
        "ROCKET_PORT": "80"
      },
      "volumes": ["data:/data"]
    }
  },
  "userEnv": [
    {
      "key": "SIGNUPS_ALLOWED",
      "label": "Allow new user signups",
      "default": "true",
      "required": false,
      "description": "Set to false to disable public registration after initial setup"
    },
    {
      "key": "ADMIN_TOKEN",
      "label": "Admin panel token",
      "default": "",
      "required": false,
      "description": "Argon2 hash or plain string to access the /admin panel. Leave empty to disable admin panel."
    }
  ],
  "resources": { "minRam": "256MB", "estimatedDisk": "500MB" }
}
