{
  "name": "atlas",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client",
    "packages/desktop"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@atlas-platform/client --filter=@atlas-platform/server --filter=@atlas-platform/shared",
    "dev:web": "turbo run dev --filter=@atlas-platform/client --filter=@atlas-platform/server",
    "dev:desktop": "concurrently --kill-others \"npm run dev:web\" \"wait-on http://localhost:5180 && npm run dev --workspace=@atlas-platform/desktop\"",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "packageManager": "npm@10.9.4",
  "overrides": {
    "@tiptap/extension-color": "2.27.2",
    "@tiptap/extension-highlight": "2.27.2",
    "@tiptap/extension-text-style": "2.27.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@preact/signals": "^2.8.1",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/extension-unique-id": "^3.20.0",
    "@types/bcryptjs": "^2.4.6",
    "ag-grid-react": "^35.1.0",
    "bcryptjs": "^3.0.3",
    "temporal-polyfill": "^0.3.0"
  }
}
