{
  "name": "atlas",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@atlas-platform/client --filter=@atlas-platform/server --filter=@atlas-platform/shared",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "packageManager": "npm@10.9.4",
  "overrides": {
    "@tiptap/extension-color": "2.27.2",
    "@tiptap/extension-highlight": "2.27.2",
    "@tiptap/extension-text-style": "2.27.2",
    "vite": "^8.0.8",
    "dompurify": "^3.4.0",
    "follow-redirects": "^1.16.0",
    "nanoid": "^5.1.7",
    "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {}
}
