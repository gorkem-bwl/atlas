# ─── Atlas Production Configuration ─────────────────────────────

NODE_ENV=production
PORT=3001

# ─── Database ────────────────────────────────────────────────────
# SQLite path for per-tenant mail data (inside the mounted volume)
DATABASE_URL=./data/atlasmail.db
# PostgreSQL for platform/marketplace tables
DATABASE_PLATFORM_URL=postgresql://atlas:CHANGE_ME@postgres:5432/atlas_platform

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ─── Security (REQUIRED — generate with: openssl rand -hex 32) ─
JWT_SECRET=CHANGE_ME_32_CHAR_HEX
JWT_REFRESH_SECRET=CHANGE_ME_32_CHAR_HEX
TOKEN_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX

# ─── Public URLs ─────────────────────────────────────────────────
SERVER_PUBLIC_URL=https://api.yourdomain.com
PLATFORM_PUBLIC_URL=https://api.yourdomain.com
CLIENT_PUBLIC_URL=https://yourdomain.com

# ─── Google OAuth (optional — for Gmail integration) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.youremailprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=Atlas <noreply@yourdomain.com>

# ─── Platform ───────────────────────────────────────────────────
PLATFORM_RUNTIME=docker
ADDON_PG_ADMIN_URL=postgresql://atlas:CHANGE_ME@postgres:5432/postgres
ADDON_REDIS_URL=redis://:CHANGE_ME@redis:6379

# ─── System Admin ───────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate with: node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)"
ADMIN_PASSWORD_HASH=CHANGE_ME

# ─── OIDC (required for SSO to installed apps) ──────────────────
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
OIDC_SIGNING_KEY="-----BEGIN PRIVATE KEY-----
CHANGE_ME
-----END PRIVATE KEY-----"

# ─── Docker Compose Vars ────────────────────────────────────────
ATLAS_DOMAIN=yourdomain.com
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
ACME_EMAIL=admin@yourdomain.com
